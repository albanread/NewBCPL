# Probe matrix manifest — input for `newbcpl-test-matrix`.
#
# Format: `<kind> <name> ::= <source> ==> <expected>`
#   kind = probe | probe_contains | reject
# Escapes in source / expected: \n \t \r \\ \"
# Comments start with `#`. Blank lines ignored.
#
# Regenerate the matching `matrix_generated.rs` with:
#   cargo run -p newbcpl-test-matrix -- \
#     tests/newbcpl-tests/matrix/generated.matrix \
#     tests/newbcpl-tests/tests/matrix_generated.rs
#
# Each row is one cell of the test matrix in `docs/test_matrix.md`.

# ─── Tier 3: arithmetic edge cases that don't fit the hand-written file ───
probe int_max_arith ::= LET START() BE $( WRITEN(1000000 * 1000) $) ==> 1000000000
probe int_neg_div ::= LET START() BE $( WRITEN(-100 / 4) $) ==> -25
probe int_zero_div_by_self_via_branch ::= LET START() BE $( IF 1 = 1 THEN WRITEN(0) $) ==> 0
probe int_double_negation ::= LET START() BE $( WRITEN(0 - (0 - 42)) $) ==> 42
probe int_paren_chain_three_deep ::= LET START() BE $( WRITEN(((1 + 2) * (3 + 4)) - ((5 - 1) * 2)) $) ==> 13

# ─── Tier 4: control flow combinations ─────────────────────────────────
# Negative-step FOR loops — `lower_for` picks the comparator from
# the step's sign at compile time (literal-only; runtime-typed
# steps still default to `<=`).
probe for_with_negative_step ::= LET START() BE $(\n  LET total = 0\n  FOR i = 5 TO 1 BY -1 DO total := total + i\n  WRITEN(total)\n$)\n ==> 15
probe while_loop_summing_first_ten ::= LET START() BE $(\n  LET sum = 0\n  LET i = 1\n  WHILE i <= 10 DO $( sum := sum + i\n i := i + 1 $)\n  WRITEN(sum)\n$)\n ==> 55
probe switchon_with_consecutive_cases ::= LET START() BE $(\n  LET n = 2\n  SWITCHON n INTO $(\n    CASE 1: CASE 2: CASE 3: WRITES(\"low\") ENDCASE\n    CASE 4: CASE 5: WRITES(\"high\") ENDCASE\n    DEFAULT: WRITES(\"?\") ENDCASE\n  $)\n$) ==> low

# ─── Tier 5: small class arithmetic ─────────────────────────────────
probe class_holds_then_doubles ::= CLASS T $(\n  DECL n\n  ROUTINE CREATE(x) BE $( SELF.n := x $)\n  FUNCTION doubled() = SELF.n * 2\n$)\nLET START() BE $( LET t = NEW T(21)\n WRITEN(t.doubled()) $) ==> 42

# ─── Tier 6: list / VEC integration ─────────────────────────────────
probe list_singleton_round_trip ::= LET START() BE $( LET xs = LIST(42)\n WRITEN(LEN(xs)) WRITES(\"*S\") WRITEN(HD(xs)) $) ==> 1 42
probe vec_empty_init_list ::= LET START() BE $( LET v = VEC(1, 2, 3, 4, 5)\n WRITEN(LEN(v)) $) ==> 5

# ─── Tier 7: SIMD lane sums ─────────────────────────────────────────
probe pair_lane_sum ::= LET START() BE $( LET p = PAIR(7, 13)\n WRITEN(p.|0| + p.|1|) $) ==> 20
probe oct_lane_sum ::= LET START() BE $( LET o = OCT(1, 2, 3, 4, 5, 6, 7, 8)\n WRITEN(o.|0| + o.|1| + o.|2| + o.|3| + o.|4| + o.|5| + o.|6| + o.|7|) $) ==> 36

# ─── Tier 1 negatives ──────────────────────────────────────────────
reject for_without_to ::= LET START() BE $( FOR i = 1 DO WRITES(\"x\") $) ==> TO
reject switchon_without_block ::= LET START() BE $( SWITCHON 1 INTO CASE 1: WRITES(\"a\") $) ==> SWITCHON
reject empty_let_rejected ::= LET START() BE $( LET $) ==> parse

# ─── Stdout-contains probes for runtime introspection ──────────────
probe_contains heap_info_mentions_clusters ::= LET START() BE $( HEAP_INFO() $)\n ==> clusters:
